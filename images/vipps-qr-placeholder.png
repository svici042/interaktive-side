<!-- QR placeholder SVG saved with .png extension -->
<svg xmlns="http://www.w3.org/2000/svg" width="400" height="400" viewBox="0 0 400 400">
  <rect width="100%" height="100%" fill="#0b1220"/>
  <rect x="40" y="40" width="320" height="320" fill="#07121a" stroke="#173a3f" stroke-width="2"/>
  <text x="200" y="210" font-size="40" fill="#7cdbff" text-anchor="middle" font-family="sans-serif">QR</text>
  <text x="200" y="250" font-size="12" fill="#9aa6b2" text-anchor="middle" font-family="sans-serif">Vipps QR placeholder</text>
</svg>
